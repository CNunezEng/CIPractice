pipeline {
    agent {
        label 'jenkins-agent-1'
    }

    stages {
        stage('clean') {
            steps {
                sh 'cmake -E rm -rf build'
            }
        }

        stage('Configure') {
            steps {
                sh 'cmake -S . -B build'
            }
        }

        stage('Build') {
            steps {
                sh 'cmake --build build'
            }
        }

        stage('Test') {
            steps {
                sh 'ctest --test-dir build --output-on-failure'
            }
        }
    }
}
